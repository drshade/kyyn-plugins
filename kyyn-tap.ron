// The first-party kyyn tap — advertised plugins and the binary serving
// them (`kyyn-plugins --plugin <name>`, one RON request per invocation).
// Each plugin's `config` block drives the web install form; a drift test in
// src/main.rs proves every example assembles into a config the plugin
// actually accepts.
(
    tap: 1,
    binary: "kyyn-plugins",
    plugins: [
        (name: "sweep", summary: "Glob a local directory tree into hashed, versioned evidence.",
         namespace: "file",
         config: [
            (name: "root", doc: "The directory tree to sweep (~ expands).", ty: Path, required: true, example: Some("~/notes")),
            (name: "patterns", doc: "Globs relative to root; * stays within one level, ** crosses.", ty: StrList, example: Some("**/*.md"), default: Some("**/*")),
            (name: "kind", doc: "The item kind swept files carry.", default: Some("file")),
            (name: "max_file_bytes", doc: "Per-file size cap; larger files skip with a note.", ty: Int, default: Some("67108864")),
         ]),
        (name: "kb", summary: "Ingest another kyyn KB as evidence — federation via curation.",
         namespace: "kb",
         capabilities: (network: ["(the configured KB remote)"]),
         config: [
            (name: "url", doc: "Git URL or local path of the remote KB's ontology repo.", ty: Path, required: true, example: Some("git@github.com:team/their-kb.git")),
            (name: "git_ref", doc: "Branch or tag to read.", default: Some("main")),
            (name: "include", doc: "Paths swept as evidence, relative to the remote root.", ty: StrList, default: Some("facts/**, receipts/**")),
         ]),
        (name: "git-repo", summary: "Any git repository's tree (local or remote) at a ref, swept as versioned evidence.",
         namespace: "repo",
         capabilities: (network: ["(the configured git remote)"]),
         config: [
            (name: "url", doc: "Git URL or local path of the repository.", ty: Path, required: true, example: Some("https://github.com/org/repo")),
            (name: "git_ref", doc: "Branch or tag to read; HEAD = the default branch.", default: Some("HEAD")),
            (name: "patterns", doc: "Globs over repo-relative paths, sweep semantics.", ty: StrList, example: Some("docs/**/*.md"), default: Some("**/*")),
            (name: "kind", doc: "The item kind swept files carry.", default: Some("file")),
            (name: "max_file_bytes", doc: "Per-file size cap; larger files skip with a note.", ty: Int, default: Some("67108864")),
         ]),
        (name: "salesforce", summary: "A SOQL query's records as evidence, via a Connected App device-flow sign-in.",
         namespace: "sf",
         capabilities: (network: ["(the configured My Domain)", "login.salesforce.com"], auth: Some("salesforce")),
         config: [
            (name: "instance_url", doc: "The org's My Domain URL.", required: true, example: Some("https://acme.my.salesforce.com")),
            (name: "client_id", doc: "The Connected App's consumer key (device flow enabled; not a secret).", required: true, example: Some("3MVG9…")),
            (name: "query", doc: "The SOQL query whose records this source ingests.", required: true, example: Some("SELECT Id, Name, StageName FROM Opportunity")),
            (name: "kind", doc: "The item kind records carry.", default: Some("sf-record")),
            (name: "api_version", doc: "REST API version.", default: Some("v62.0")),
            (name: "id_field", doc: "The field carrying each record's stable identity.", default: Some("Id")),
         ]),
        (name: "graph-mail", summary: "Microsoft 365 mail (with attachments); narrow with mail_filter.",
         namespace: "graph",
         capabilities: (network: ["graph.microsoft.com", "login.microsoftonline.com"], auth: Some("ms-graph")),
         config: [
            (name: "mail_filter", doc: "OData $filter fragment ANDed onto the mail window — e.g. from/emailAddress/address eq 'x@y.com'.", example: Some("contains(subject, 'Sales Update')")),
            (name: "owner_addresses", doc: "Your own addresses (lowercased) — classifies sent vs received.", ty: StrList, example: Some("you@company.com")),
            (name: "client_id", doc: "Azure app id — leave empty for the shared multi-tenant kyyn app.", default: Some("53ddb21b-849f-45a3-8168-8a0e555f386f")),
            (name: "tenant", doc: "Entra tenant GUID, or organizations (any work/school directory).", default: Some("organizations")),
         ]),
        (name: "graph-calendar", summary: "Microsoft 365 calendar events.",
         namespace: "graph",
         capabilities: (network: ["graph.microsoft.com", "login.microsoftonline.com"], auth: Some("ms-graph")),
         config: [
            (name: "owner_addresses", doc: "Your own addresses (lowercased).", ty: StrList, example: Some("you@company.com")),
            (name: "client_id", doc: "Azure app id — leave empty for the shared multi-tenant kyyn app.", default: Some("53ddb21b-849f-45a3-8168-8a0e555f386f")),
            (name: "tenant", doc: "Entra tenant GUID, or organizations.", default: Some("organizations")),
         ]),
        (name: "graph-meetings", summary: "Teams meetings that carry transcripts or attendance reports.",
         namespace: "graph",
         capabilities: (network: ["graph.microsoft.com", "login.microsoftonline.com"], auth: Some("ms-graph")),
         config: [
            (name: "owner_addresses", doc: "Your own addresses (lowercased).", ty: StrList, example: Some("you@company.com")),
            (name: "client_id", doc: "Azure app id — leave empty for the shared multi-tenant kyyn app.", default: Some("53ddb21b-849f-45a3-8168-8a0e555f386f")),
            (name: "tenant", doc: "Entra tenant GUID, or organizations.", default: Some("organizations")),
         ]),
        (name: "graph-chats", summary: "Teams chats and their messages (the slow crawl).",
         namespace: "graph",
         capabilities: (network: ["graph.microsoft.com", "login.microsoftonline.com"], auth: Some("ms-graph")),
         config: [
            (name: "owner_addresses", doc: "Your own addresses (lowercased).", ty: StrList, example: Some("you@company.com")),
            (name: "client_id", doc: "Azure app id — leave empty for the shared multi-tenant kyyn app.", default: Some("53ddb21b-849f-45a3-8168-8a0e555f386f")),
            (name: "tenant", doc: "Entra tenant GUID, or organizations.", default: Some("organizations")),
         ]),
        (name: "sharepoint-file", summary: "A tracked SharePoint/OneDrive file or folder, snapshot-fetched.",
         namespace: "sharepoint",
         capabilities: (network: ["graph.microsoft.com", "login.microsoftonline.com", "*.sharepoint.com"], auth: Some("ms-graph")),
         config: [
            (name: "url", doc: "The sharing link of the tracked file or folder.", required: true, example: Some("https://acme.sharepoint.com/:f:/r/sites/…")),
            (name: "patterns", doc: "Folder targets: globs over folder-relative paths.", ty: StrList, example: Some("**/*.xlsx"), default: Some("**/*")),
            (name: "kind", doc: "The item kind fetched files carry.", default: Some("file")),
            (name: "max_file_bytes", doc: "Per-file size cap; larger files skip with a note.", ty: Int, default: Some("67108864")),
            (name: "client_id", doc: "Azure app id — leave empty for the shared multi-tenant kyyn app.", default: Some("53ddb21b-849f-45a3-8168-8a0e555f386f")),
            (name: "tenant", doc: "Entra tenant GUID, or organizations.", default: Some("organizations")),
         ]),
    ],
)
